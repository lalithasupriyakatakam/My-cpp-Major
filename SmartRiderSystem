// ==================== Basic Data Structures ====================

struct Location {
    int x, y;
    Location(int x = 0, int y = 0) : x(x), y(y) {}
    
    double distanceTo(const Location& other) const {
        return sqrt(pow(x - other.x, 2) + pow(y - other.y, 2));
    }
    
    bool operator==(const Location& other) const {
        return x == other.x && y == other.y;
    }
    
    // Add comparison operator for using in pair
    bool operator<(const Location& other) const {
        if (x != other.x) return x < other.x;
        return y < other.y;
    }
};

// Custom hash function for Location
struct LocationHash {
    size_t operator()(const Location& loc) const {
        return hash<int>()(loc.x) ^ (hash<int>()(loc.y) << 1);
    }
};

// ==================== Graph Structure ====================

class RoadGraph {
private:
    unordered_map<Location, vector<pair<Location, double>>, LocationHash> adjList;
    
public:
    void addEdge(const Location& u, const Location& v, double distance) {
        adjList[u].push_back({v, distance});
        adjList[v].push_back({u, distance});
    }
    
    // Make this const to work with const references
    vector<pair<Location, double>> getNeighbors(const Location& node) const {
        auto it = adjList.find(node);
        if (it != adjList.end())
            return it->second;
        return {};
    }
};

// ==================== Path Finding ====================

class PathFinder {
public:
    struct PathResult {
        double distance;
        vector<Location> path;
        bool found;
        
        PathResult() : distance(0), found(false) {}
    };
    
    static PathResult dijkstra(const RoadGraph& graph, const Location& start, const Location& dest) {
        unordered_map<Location, double, LocationHash> dist;
        unordered_map<Location, Location, LocationHash> prev;
        
        // Using priority queue with pair<double, Location>
        priority_queue<pair<double, Location>, vector<pair<double, Location>>, greater<pair<double, Location>>> pq;
        
        dist[start] = 0;
        pq.push({0, start});
        
        while (!pq.empty()) {
            Location current = pq.top().second;
            double currentDist = pq.top().first;
            pq.pop();
            
            if (currentDist > dist[current]) continue;
            
            if (current == dest) {
                // Reconstruct path
                vector<Location> path;
                Location node = dest;
                while (!(node == start)) {
                    path.push_back(node);
                    node = prev[node];
                }
                path.push_back(start);
                reverse(path.begin(), path.end());
                
                PathResult result;
                result.distance = currentDist;
                result.path = path;
                result.found = true;
                return result;
            }
            
            vector<pair<Location, double>> neighbors = graph.getNeighbors(current);
            for (size_t i = 0; i < neighbors.size(); i++) {
                Location next = neighbors[i].first;
                double weight = neighbors[i].second;
                double newDist = currentDist + weight;
                
                if (dist.find(next) == dist.end() || newDist < dist[next]) {
                    dist[next] = newDist;
                    prev[next] = current;
                    pq.push({newDist, next});
                }
            }
        }
        
        PathResult result;
        result.distance = numeric_limits<double>::max();
        result.found = false;
        return result;
    }
};

// ==================== Driver Class ====================

class Driver {
public:
    int id;
    string name;
    Location currentLocation;
    bool isAvailable;
    double rating;
    int totalRides;
    double earnings;
    
    Driver(int id, string name, Location loc) 
        : id(id), name(name), currentLocation(loc), 
          isAvailable(true), rating(5.0), totalRides(0), earnings(0.0) {}
};

// ==================== Ride Class ====================

class Ride {
public:
    int id;
    int userId;
    int driverId;
    Location pickup;
    Location dropoff;
    double distance;
    double fare;
    time_t startTime;
    time_t endTime;
    string status;
    
    Ride(int id, int userId, Location pickup, Location dropoff)
        : id(id), userId(userId), pickup(pickup), dropoff(dropoff),
          driverId(-1), distance(0), fare(0), startTime(time(nullptr)), 
          status("requested") {}
};

// ==================== Demand Predictor ====================

class DemandPredictor {
public:
    double predictDemand(int hour) {
        // Simple prediction based on time of day
        if (hour >= 7 && hour <= 9) return 80.0;      // Morning rush
        if (hour >= 17 && hour <= 19) return 90.0;    // Evening rush
        if (hour >= 12 && hour <= 14) return 60.0;    // Lunch time
        if (hour >= 22 || hour <= 5) return 20.0;     // Late night
        return 40.0;                                    // Regular hours
    }
    
    vector<Location> findHighDemandAreas(const vector<Location>& areas, int hour) {
        vector<pair<double, Location>> demandAreas;
        
        for (size_t i = 0; i < areas.size(); i++) {
            double demand = predictDemand(hour);
            // Add some location-based variation
            demand += (areas[i].x + areas[i].y) % 20;
            demandAreas.push_back({demand, areas[i]});
        }
        
        // Sort by demand (highest first)
        sort(demandAreas.begin(), demandAreas.end());
        reverse(demandAreas.begin(), demandAreas.end());
        
        vector<Location> highDemandAreas;
        int topCount = min(3, (int)demandAreas.size());
        for (int i = 0; i < topCount; i++) {
            highDemandAreas.push_back(demandAreas[i].second);
        }
        
        return highDemandAreas;
    }
};

// ==================== Dynamic Pricing ====================

class DynamicPricing {
private:
    double baseFare;
    double perKmRate;
    
public:
    DynamicPricing() : baseFare(5.0), perKmRate(2.0) {}
    
    double calculateFare(double distance, int currentDemand, int availableDrivers, int hour) {
        double demandSupplyRatio = (double)currentDemand / max(1, availableDrivers);
        
        // Base multiplier
        double multiplier = 1.0;
        
        // Surge based on demand/supply ratio
        if (demandSupplyRatio > 1.5) {
            multiplier = 1.0 + (demandSupplyRatio - 1.5) * 0.5;
        }
        
        // Time-based surge (rush hours)
        if ((hour >= 7 && hour <= 9) || (hour >= 17 && hour <= 19)) {
            multiplier *= 1.3;
        }
        
        // Cap the multiplier
        if (multiplier > 3.0) multiplier = 3.0;
        
        return (baseFare + distance * perKmRate) * multiplier;
    }
};

// ==================== Ride Matching Engine ====================

class RideMatchingEngine {
private:
    RoadGraph graph;
    unordered_map<int, Driver> drivers;
    unordered_map<int, Ride> rides;
    DemandPredictor predictor;
    DynamicPricing pricing;
    
public:
    RideMatchingEngine() {
        // Initialize with some drivers for testing
        drivers.insert({1, Driver(1, "John", Location(0, 0))});
        drivers.insert({2, Driver(2, "Alice", Location(5, 5))});
        drivers.insert({3, Driver(3, "Bob", Location(10, 10))});
        
        // Initialize road graph
        setupRoadNetwork();
    }
    
    void setupRoadNetwork() {
        // Create a simple grid network
        for (int i = 0; i <= 20; i++) {
            for (int j = 0; j <= 20; j++) {
                Location current(i, j);
                
                if (i < 20) {
                    Location right(i + 1, j);
                    graph.addEdge(current, right, 1.0);
                }
                if (j < 20) {
                    Location down(i, j + 1);
                    graph.addEdge(current, down, 1.0);
                }
            }
        }
    }
    
    Driver* findNearestDriver(const Location& pickup) {
        Driver* nearestDriver = nullptr;
        double minDistance = numeric_limits<double>::max();
        
        // Manual iteration
        for (auto it = drivers.begin(); it != drivers.end(); ++it) {
            Driver& driver = it->second;
            if (driver.isAvailable) {
                double distance = pickup.distanceTo(driver.currentLocation);
                if (distance < minDistance) {
                    minDistance = distance;
                    nearestDriver = &driver;
                }
            }
        }
        
        return nearestDriver;
    }
    
    int requestRide(int userId, const Location& pickup, const Location& dropoff) {
        static int rideCounter = 0;
        int rideId = ++rideCounter;
        
        Ride newRide(rideId, userId, pickup, dropoff);
        
        // Find nearest driver
        Driver* driver = findNearestDriver(pickup);
        
        if (driver) {
            newRide.driverId = driver->id;
            newRide.status = "accepted";
            
            // Calculate distance (simplified - using Euclidean)
            newRide.distance = pickup.distanceTo(dropoff);
            
            // Calculate fare with dynamic pricing
            int hour = getCurrentHour();
            int demand = getCurrentDemand();
            int availableDrivers = getAvailableDrivers();
            
            newRide.fare = pricing.calculateFare(newRide.distance, demand, availableDrivers, hour);
            
            // Update driver availability
            driver->isAvailable = false;
            driver->currentLocation = pickup;
            
            cout << "Driver " << driver->name << " assigned to ride " << rideId << endl;
        } else {
            cout << "No drivers available for ride " << rideId << endl;
        }
        
        rides.insert({rideId, newRide});
        return rideId;
    }
    
    void completeRide(int rideId) {
        auto it = rides.find(rideId);
        if (it != rides.end()) {
            Ride& ride = it->second;
            ride.status = "completed";
            ride.endTime = time(nullptr);
            
            // Update driver stats
            auto driverIt = drivers.find(ride.driverId);
            if (driverIt != drivers.end()) {
                Driver& driver = driverIt->second;
                driver.isAvailable = true;
                driver.totalRides++;
                driver.earnings += ride.fare;
                driver.currentLocation = ride.dropoff;
                
                cout << "Ride " << rideId << " completed. Fare: $" << ride.fare << endl;
            }
        }
    }
    
    vector<Location> predictHighDemandAreas() {
        vector<Location> areas;
        for (int i = 0; i <= 20; i += 5) {
            for (int j = 0; j <= 20; j += 5) {
                areas.push_back(Location(i, j));
            }
        }
        
        int hour = getCurrentHour();
        return predictor.findHighDemandAreas(areas, hour);
    }
    
    void rebalanceDrivers() {
        vector<Location> highDemandAreas = predictHighDemandAreas();
        
        if (highDemandAreas.empty()) return;
        
        cout << "\n--- Rebalancing Drivers ---" << endl;
        cout << "High demand areas: ";
        for (size_t i = 0; i < highDemandAreas.size(); i++) {
            cout << "(" << highDemandAreas[i].x << "," << highDemandAreas[i].y << ") ";
        }
        cout << endl;
        
        // Move available drivers towards high demand areas
        for (auto it = drivers.begin(); it != drivers.end(); ++it) {
            Driver& driver = it->second;
            if (driver.isAvailable) {
                // Find nearest high demand area
                Location target = highDemandAreas[0];
                double minDist = driver.currentLocation.distanceTo(target);
                
                for (size_t i = 1; i < highDemandAreas.size(); i++) {
                    double dist = driver.currentLocation.distanceTo(highDemandAreas[i]);
                    if (dist < minDist) {
                        minDist = dist;
                        target = highDemandAreas[i];
                    }
                }
                
                // Move driver slightly towards target
                int dx = 0, dy = 0;
                if (target.x > driver.currentLocation.x) dx = 1;
                else if (target.x < driver.currentLocation.x) dx = -1;
                
                if (target.y > driver.currentLocation.y) dy = 1;
                else if (target.y < driver.currentLocation.y) dy = -1;
                
                driver.currentLocation.x += dx;
                driver.currentLocation.y += dy;
                
                cout << "Moving " << driver.name << " towards (" 
                     << target.x << "," << target.y << ")" << endl;
            }
        }
    }
    
    // Helper functions
    int getCurrentHour() {
        time_t now = time(nullptr);
        tm* lt = localtime(&now);
        return lt->tm_hour;
    }
    
    int getCurrentDemand() {
        int hour = getCurrentHour();
        return (int)predictor.predictDemand(hour);
    }
    
    int getAvailableDrivers() {
        int count = 0;
        for (auto it = drivers.begin(); it != drivers.end(); ++it) {
            if (it->second.isAvailable) count++;
        }
        return count;
    }
    
    void printSystemStatus() {
        cout << "\n=== System Status ===" << endl;
        cout << "Available Drivers: " << getAvailableDrivers() << endl;
        cout << "Current Demand: " << getCurrentDemand() << endl;
        cout << "Current Hour: " << getCurrentHour() << ":00" << endl;
        
        vector<Location> highDemandAreas = predictHighDemandAreas();
        cout << "High Demand Areas: ";
        for (size_t i = 0; i < highDemandAreas.size(); i++) {
            cout << "(" << highDemandAreas[i].x << "," << highDemandAreas[i].y << ") ";
        }
        cout << endl;
        
        cout << "Driver Locations: " << endl;
        for (auto it = drivers.begin(); it != drivers.end(); ++it) {
            cout << "  " << it->second.name << ": (" 
                 << it->second.currentLocation.x << "," 
                 << it->second.currentLocation.y << ") ";
            if (!it->second.isAvailable) cout << "[Busy]";
            cout << endl;
        }
    }
};

